# PostgreSQL
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require
# Optional: force a schema (e.g. icloseddevdb or icloseddevdbfresh).
# Leave blank to use the DB role's default search_path.
PGSCHEMA=

# Stripe dashboard
STRIPE_DASHBOARD_URL=https://dashboard.stripe.com
# The environment to select in the account menu (varies per account/setup).
# Leave blank to skip switching (use whatever the saved session is on).
STRIPE_ENVIRONMENT_NAME=iclosed.io(development)
STRIPE_AUTH_PROFILE_DIR=.auth

# Timeouts
STRIPE_STEP_TIMEOUT_MS=30000
STRIPE_LONG_TIMEOUT_MS=120000

# Behavior
DEFAULT_RENEWAL_OFFSET_MINUTES=5
PLAYWRIGHT_SLOW_MO_MS=0
DRY_RUN=true
OPEN_STRIPE_IN_DRY_RUN=false
