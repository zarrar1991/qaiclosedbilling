{
  "name": "iclosed-billing-downgrade",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "db:check": "tsx src/db-check.ts",
    "db:update": "tsx src/db-update-only.ts",
    "build": "tsc -p tsconfig.json",
    "cli:start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "electron:build": "tsc -p tsconfig.electron.json && node -e \"const fs=require('fs');fs.copyFileSync('electron/preload.cjs','dist-electron/electron/preload.cjs');fs.copyFileSync('electron/iclosed-flow.cjs','dist-electron/electron/iclosed-flow.cjs')\"",
    "start": "concurrently -k \"npm:ui:dev\" \"wait-on tcp:5173 && npm run electron:build && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/electron/main.js\"",
    "app:build": "npm run ui:build && npm run electron:build && electron-builder",
    "app:build:win": "npm run ui:build && npm run electron:build && electron-builder --win",
    "app:build:mac": "npm run ui:build && npm run electron:build && electron-builder --mac"
  },
  "build": {
    "appId": "io.iclosed.billing",
    "productName": "iClosed Billing",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!.env",
      "!profiles.json",
      "!.auth/**",
      "!artifacts/**",
      "!debug/**",
      "!docs/**",
      "!.design-tmp/**",
      "!src/**",
      "!ui/**",
      "!electron/**",
      "!tests/**",
      "!dist/**",
      "!build/**",
      "!release/**",
      "!iclosed-module.zip",
      "!.iclosed-module-extract/**",
      "!run.bat",
      "!README.md",
      "!package-lock.json",
      "!tsconfig*.json",
      "!*.config.ts",
      "!*.config.js",
      "!**/*.map",
      "!**/{.git,.github,.vscode,.idea}/**"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "iClosed Billing"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.0"
  }
}
